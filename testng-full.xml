<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Online Store API Full Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="listeners.AllureTestListener"/>
        <listener class-name="listeners.TestExecutionListener"/>
    </listeners>

    <test name="Product API Tests">
        <classes>
            <class name="testcases.ProductTests"/>
        </classes>
    </test>

    <test name="Product Data-Driven Tests">
        <classes>
            <class name="testcases.ProductDataDrivenTest"/>
        </classes>
    </test>

    <test name="User API Tests">
        <classes>
            <class name="testcases.UserTests"/>
        </classes>
    </test>

    <test name="Cart API Tests">
        <classes>
            <class name="testcases.CartTests"/>
        </classes>
    </test>
</suite>
